generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String              @id @default(uuid())
  name              String?
  email             String              @unique
  phone             String?             @unique
  passwordHash      String
  role              String              @default("CUSTOMER")
  walletBalance     Int                 @default(0)
  referredById      String?
  referralCode      String              @unique
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  auditLogs         AuditLog[]
  orders            Order[]
  referralsReceived Referral?           @relation("ReferralsReceived")
  referralsMade     Referral[]          @relation("ReferralsMade")
  referredBy        User?               @relation("ReferralTree", fields: [referredById], references: [id], onDelete: Restrict)
  referredUsers     User[]              @relation("ReferralTree")
  transactions      WalletTransaction[]
}

model Bundle {
  id                  String         @id @default(uuid())
  network             String
  label               String
  dataAmountGB        Float
  supplierCostPesewas Int
  sellPricePesewas    Int
  agentPricePesewas   Int
  active              Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  orders              Order[]
  storePricing        StorePricing[]
}

model Order {
  id                 String              @id @default(uuid())
  userId             String?
  bundleId           String
  recipientPhone     String
  status             String              @default("PENDING")
  supplierOrderRef   String?             @unique
  supplierPurchaseId String?             @unique
  idempotencyKey     String?             @unique
  paystackRef        String?             @unique
  amountPaid         Int
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  bundle             Bundle              @relation(fields: [bundleId], references: [id])
  user               User?               @relation(fields: [userId], references: [id])
  walletTransactions WalletTransaction[]
  storeId            String?
  store              Store?              @relation(fields: [storeId], references: [id])
  ledgers            Ledger[]
}

model SupplierAccount {
  id                 String   @id @default("default")
  balancePesewas     Int      @default(0)
  rateLimitRemaining Int      @default(0)
  rateLimitResetAt   DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model WalletTransaction {
  id               String   @id @default(uuid())
  userId           String
  type             String
  amountPesewas    Int
  balanceAfter     Int
  referenceOrderId String?
  isArchived       Boolean  @default(false)
  createdAt        DateTime @default(now())
  notes            String?
  paymentRef       String?
  order            Order?   @relation(fields: [referenceOrderId], references: [id])
  user             User     @relation(fields: [userId], references: [id])
}

model Referral {
  id             String   @id @default(uuid())
  referrerId     String
  referredUserId String   @unique
  rewardType     String   @default("CASHBACK")
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  referredUser   User     @relation("ReferralsReceived", fields: [referredUserId], references: [id])
  referrer       User     @relation("ReferralsMade", fields: [referrerId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Store {
  id           String         @id @default(uuid())
  ownerUserId  String
  parentStoreId String?
  slug         String         @unique
  name         String
  status       String         @default("PENDING") // ACTIVE | SUSPENDED | PENDING
  storeType    String         @default("AGENT") // ROOT | AGENT
  displayName  String
  logoUrl      String?
  primaryColor String?
  supportEmail String?
  contactPhone String?
  footerText   String?
  ancestorPath String         @default("root")
  createdAt    DateTime       @default(now())
  orders       Order[]
  parentStore  Store?         @relation("StoreHierarchy", fields: [parentStoreId], references: [id], onDelete: Restrict)
  childStores  Store[]        @relation("StoreHierarchy")
  storePricing StorePricing[]
  ledgers      Ledger[]
  withdrawals  Withdrawal[]
}

model StorePricing {
  id                       String   @id @default(uuid())
  storeId                  String
  bundleId                 String
  priceForCustomersPesewas Int
  priceForSubAgentsPesewas Int
  updatedAt                DateTime @updatedAt
  store                    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  bundle                   Bundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  @@unique([storeId, bundleId])
}

model AgentApplication {
  id                    String    @id @default(uuid())
  applicantUserId       String
  parentStoreId         String
  storeName             String
  applicationFeePesewas Int
  paymentRef            String?
  status                String    @default("PENDING_PAYMENT") // PENDING_PAYMENT | PENDING_REVIEW | APPROVED | REJECTED
  reviewedByUserId      String?
  reviewedAt            DateTime?
  createdAt             DateTime  @default(now())
  ledgers               Ledger[]
}

model Ledger {
  id               String            @id @default(uuid())
  storeId          String
  orderId          String?
  applicationId    String?
  tierDepth        Int
  buyPricePesewas  Int
  sellPricePesewas Int
  amountPesewas    Int
  status           String            @default("AVAILABLE") // AVAILABLE | WITHDRAWN
  createdAt        DateTime          @default(now())
  store            Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order            Order?            @relation(fields: [orderId], references: [id])
  application      AgentApplication? @relation(fields: [applicationId], references: [id])
}

model Withdrawal {
  id                 String    @id @default(uuid())
  storeId            String
  amountPesewas      Int
  ledgerIds          String[] // Storing ledger IDs covered
  status             String    @default("PENDING") // PENDING | COMPLETED | FAILED
  payoutMethod       String    @default("MANUAL_MOMO") // MANUAL_MOMO | MANUAL_BANK | PAYSTACK_TRANSFER
  payoutReference    String?
  requestedAt        DateTime  @default(now())
  completedAt        DateTime?
  completedByUserId  String?
  store              Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
}
