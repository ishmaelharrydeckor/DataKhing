generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String              @id @default(uuid())
  name              String?
  email             String              @unique
  phone             String?             @unique
  passwordHash      String
  role              String              @default("CUSTOMER")
  walletBalance     Int                 @default(0)
  referredById      String?
  referralCode      String              @unique
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  agentApplications AgentApplication?
  payoutBatches     AgentPayoutBatch[]  @relation("AgentPayouts")
  auditLogs         AuditLog[]
  commissions       Commission[]        @relation("AgentCommissions")
  orders            Order[]
  referralsReceived Referral?           @relation("ReferralsReceived")
  referralsMade     Referral[]          @relation("ReferralsMade")
  referredBy        User?               @relation("ReferralTree", fields: [referredById], references: [id], onDelete: Restrict)
  referredUsers     User[]              @relation("ReferralTree")
  transactions      WalletTransaction[]
}

model Bundle {
  id                  String   @id @default(uuid())
  network             String
  label               String
  dataAmountGB        Float
  supplierCostPesewas Int
  sellPricePesewas    Int
  agentPricePesewas   Int
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  orders              Order[]
}

model Order {
  id                 String              @id @default(uuid())
  userId             String?
  bundleId           String
  recipientPhone     String
  status             String              @default("PENDING")
  supplierOrderRef   String?             @unique
  supplierPurchaseId String?             @unique
  idempotencyKey     String?             @unique
  paystackRef        String?             @unique
  amountPaid         Int
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  commissions        Commission[]
  bundle             Bundle              @relation(fields: [bundleId], references: [id])
  user               User?               @relation(fields: [userId], references: [id])
  walletTransactions WalletTransaction[]
}

model SupplierAccount {
  id                 String   @id @default("default")
  balancePesewas     Int      @default(0)
  rateLimitRemaining Int      @default(0)
  rateLimitResetAt   DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model WalletTransaction {
  id               String   @id @default(uuid())
  userId           String
  type             String
  amountPesewas    Int
  balanceAfter     Int
  referenceOrderId String?
  createdAt        DateTime @default(now())
  notes            String?
  paymentRef       String?
  order            Order?   @relation(fields: [referenceOrderId], references: [id])
  user             User     @relation(fields: [userId], references: [id])
}

model Referral {
  id             String   @id @default(uuid())
  referrerId     String
  referredUserId String   @unique
  rewardType     String   @default("CASHBACK")
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  referredUser   User     @relation("ReferralsReceived", fields: [referredUserId], references: [id])
  referrer       User     @relation("ReferralsMade", fields: [referrerId], references: [id])
}

model AgentApplication {
  id           String   @id @default(uuid())
  userId       String   @unique
  status       String   @default("PENDING")
  businessName String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Commission {
  id                      String            @id @default(uuid())
  agentUserId             String
  orderId                 String
  salePricePesewas        Int
  commissionRatePercent   Int
  commissionAmountPesewas Int
  status                  String            @default("PENDING")
  payoutMethod            String?
  payoutReference         String?
  notes                   String?
  payoutBatchId           String?
  createdAt               DateTime          @default(now())
  paidAt                  DateTime?
  paidByAdminId           String?
  agentUser               User              @relation("AgentCommissions", fields: [agentUserId], references: [id])
  order                   Order             @relation(fields: [orderId], references: [id])
  payoutBatch             AgentPayoutBatch? @relation(fields: [payoutBatchId], references: [id])
}

model AgentPayoutBatch {
  id                 String       @id @default(uuid())
  agentUserId        String
  totalAmountPesewas Int
  status             String       @default("PENDING")
  createdAt          DateTime     @default(now())
  completedAt        DateTime?
  createdByAdminId   String?
  agentUser          User         @relation("AgentPayouts", fields: [agentUserId], references: [id])
  commissions        Commission[]
}
